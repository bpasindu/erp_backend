{
  "info": {
    "name": "ERP Inventory APIs",
    "description": "Add stock, view inventory, view product stock, and related endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "YOUR_JWT_TOKEN" },
    { "key": "businessId", "value": "7" },
    { "key": "warehouseId", "value": "1" },
    { "key": "productId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login to get JWT. Save token to collection variable for other requests."
          }
        }
      ]
    },
    {
      "name": "Add Stock",
      "item": [
        {
          "name": "Add Stock (POST add-stock)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"batchNumber\": \"BATCH-001\",\n  \"quantity\": 100,\n  \"costPrice\": 250,\n  \"warehouseId\": {{warehouseId}}\n}"
            },
            "url": "{{baseUrl}}/api/inventory/add-stock",
            "description": "Creates/updates batch, creates IN movement, updates warehouse balance and product total quantity."
          }
        }
      ]
    },
    {
      "name": "View Inventory",
      "item": [
        {
          "name": "Get inventory balances by business",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/inventory/balances/business/{{businessId}}",
            "description": "Returns all inventory balances (warehouse-product quantities) for the business."
          }
        },
        {
          "name": "Get movements by warehouse",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/inventory/movements/warehouse/{{warehouseId}}",
            "description": "Returns stock movements (IN/OUT) for a warehouse."
          }
        }
      ]
    },
    {
      "name": "View Product Stock",
      "item": [
        {
          "name": "Get products by business",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products/business/{{businessId}}",
            "description": "Returns all products for the business (includes stockQuantity per product)."
          }
        },
        {
          "name": "Get single product",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "description": "Returns one product with stockQuantity."
          }
        }
      ]
    },
    {
      "name": "Record movement (IN/OUT)",
      "item": [
        {
          "name": "Record stock movement",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessId\": {{businessId}},\n  \"warehouseId\": {{warehouseId}},\n  \"productId\": {{productId}},\n  \"quantity\": 50,\n  \"type\": \"IN\"\n}"
            },
            "url": "{{baseUrl}}/api/inventory/movement",
            "description": "Record a generic IN or OUT movement (updates balance and creates movement record)."
          }
        }
      ]
    },
    {
      "name": "Warehouses",
      "item": [
        {
          "name": "Get warehouses by business",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/warehouses/business/{{businessId}}",
            "description": "List warehouses for the business (used by invoices when no inventory balances exist yet)."
          }
        }
      ]
    }
  ]
}
